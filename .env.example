# Copy this file to .env and fill values for local development

# Snowflake (prefer externalbrowser auth via Snowflake CLI; avoid passwords in files)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# dbt
DBT_TARGET=dev
# dbt reads profiles from ~/.dbt/profiles.yml by default.
# Only set DBT_PROFILES_DIR if you intentionally keep profiles somewhere else.

# Optional: run.sh can use this for Snowflake SQL health checks
SNOW_CONNECTION=my_snowflake
